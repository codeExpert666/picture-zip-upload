COMPOSE_PROJECT_NAME=picture-zip-upload-prod
DOCKER_PLATFORM=linux/amd64
TZ=Asia/Shanghai

BACKEND_IMAGE=registry.example.com/company/picture-zip-upload:replace-with-release-tag
MAVEN_IMAGE=maven:3.9.0-eclipse-temurin-17@sha256:8d19f7daf6e637d8ff45314861f964b08cee4279d8230c9fc4e4cc002e1c16e4
RUNTIME_IMAGE=eclipse-temurin:17-jre-jammy@sha256:475d8e96b4b2bfe08999e5e854755c773af1581acdf959a4545d88f0696a2339
# Prefer a company Maven settings.xml/CI secret for authenticated mirrors.
MAVEN_BUILD_OPTS=
APP_UID=10001
APP_GID=10001
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

BACKEND_PORT=18080
BACKEND_MEMORY_LIMIT=2g
BACKEND_CPUS=2.0
BACKEND_PIDS_LIMIT=256

# Existing Ubuntu host services. This Compose file never creates MySQL or Redis.
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/ai_dataset?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=replace-me
MYSQL_PASSWORD=replace-me
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# Existing persistent host directories. They are never copied into the image.
PICTURE_WORK_HOST_PATH=/data/picture-upload-work
PICTURE_IMAGE_HOST_PATH=/data/pictures
PICTURE_LEGACY_HOST_PATH=/data/corpusImages

MAINTENANCE_MODE=IMPORT_DIRECT
MAINTENANCE_DRY_RUN=true
MAINTENANCE_BUSINESS_AREA=medical
MAINTENANCE_OPERATOR=replace-me
MAINTENANCE_BATCH_ID=replace-me
MAINTENANCE_SOURCE_ROOT=/data/pictures
MAINTENANCE_LEGACY_ROOT=/data/corpusImages
MAINTENANCE_LIMIT=1000
