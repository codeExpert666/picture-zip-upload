COMPOSE_PROJECT_NAME=picture-zip-upload-local
DOCKER_PLATFORM=linux/amd64
TZ=Asia/Shanghai

BACKEND_IMAGE=picture-zip-upload:local
MAVEN_IMAGE=maven:3.9.0-eclipse-temurin-17@sha256:8d19f7daf6e637d8ff45314861f964b08cee4279d8230c9fc4e4cc002e1c16e4
RUNTIME_IMAGE=eclipse-temurin:17-jre-jammy@sha256:475d8e96b4b2bfe08999e5e854755c773af1581acdf959a4545d88f0696a2339
# Optional Maven JVM options for a company repository proxy; do not put credentials here.
MAVEN_BUILD_OPTS=
APP_UID=10001
APP_GID=10001
JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=75.0 -Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

MYSQL_IMAGE=mysql:5.7.44@sha256:4bc6bc963e6d8443453676cae56536f4b8156d78bae03c0145cbe47c2aad73bb
MYSQL_DATABASE=ai_dataset
MYSQL_USERNAME=picture_app
MYSQL_PASSWORD=local-app-change-me
MYSQL_ROOT_PASSWORD=local-root-change-me
MYSQL_EXPOSED_PORT=3307

REDIS_IMAGE=redis:5.0.14-bullseye@sha256:fc5ecd863862f89f04334b7cbb57e93c9790478ea8188a49f6e57b0967d38c75
REDIS_PASSWORD=local-redis-change-me
REDIS_EXPOSED_PORT=6380

BACKEND_PORT=8080

# maintenance profile stays dry-run unless explicitly changed for one invocation.
MAINTENANCE_MODE=IMPORT_DIRECT
MAINTENANCE_DRY_RUN=true
MAINTENANCE_BUSINESS_AREA=medical
MAINTENANCE_OPERATOR=docker-operator
MAINTENANCE_BATCH_ID=docker-dry-run
MAINTENANCE_SOURCE_ROOT=/data/pictures
MAINTENANCE_LEGACY_ROOT=/data/corpusImages
MAINTENANCE_LIMIT=1000
